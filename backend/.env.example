# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it's in .gitignore for a reason.

# Get your Anthropic API key from: https://console.anthropic.com
# This key lets us call Claude (the LLM that powers all 8 agents).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get your Tavily API key from: https://tavily.com
# Free tier gives 1000 searches/month — plenty for development.
# Tavily is the web search tool used by researchAgent, flightsAgent,
# carRentalAgent, and hotelsAgent to fetch real-world data.
TAVILY_API_KEY=your_tavily_api_key_here

# The port Express listens on. 3001 is chosen to avoid conflict with
# React's default port (5173 for Vite, 3000 for Create React App).
PORT=3001
